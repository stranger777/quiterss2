####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/usr/bin || mkdir -p $(INSTALL_ROOT)/usr/bin
	$(QINSTALL_PROGRAM) bin/$(QMAKE_TARGET) $(INSTALL_ROOT)/usr/bin/$(QMAKE_TARGET)
	-$(STRIP) $(INSTALL_ROOT)/usr/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/usr/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/bin/ 


install_target1: first FORCE
	@test -d $(INSTALL_ROOT)/usr/share/applications || mkdir -p $(INSTALL_ROOT)/usr/share/applications
	$(QINSTALL) /workspace/platforms/linux/quiterss.desktop $(INSTALL_ROOT)/usr/share/applications/quiterss.desktop

uninstall_target1: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/applications/quiterss.desktop
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/share/applications/ 


install_translations: first FORCE
	@test -d $(INSTALL_ROOT)/usr/share/quiterss || mkdir -p $(INSTALL_ROOT)/usr/share/quiterss
	$(QINSTALL) /workspace/bin/translations $(INSTALL_ROOT)/usr/share/quiterss/translations

uninstall_translations: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/quiterss/translations
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/share/quiterss/ 


install_sound: first FORCE
	@test -d $(INSTALL_ROOT)/usr/share/quiterss || mkdir -p $(INSTALL_ROOT)/usr/share/quiterss
	$(QINSTALL) /workspace/resources/sound $(INSTALL_ROOT)/usr/share/quiterss/sound

uninstall_sound: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/quiterss/sound
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/share/quiterss/ 


install: install_target install_target1 install_translations install_sound  FORCE

uninstall: uninstall_target uninstall_target1 uninstall_translations uninstall_sound  FORCE

FORCE:

