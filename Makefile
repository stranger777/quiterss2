	$(COPY_FILE) --parents /usr/lib/x86_64-linux-gnu/qt5/mkspecs/features/data/dummy.cpp $(DISTDIR)/
	$(COPY_FILE) --parents src/application/application.h src/systemtray/systemtray.h src/application/logfile.h src/application/settings.h src/common/common.h src/network/networkmanager.h src/webengine/cookiejar.h src/webengine/webengine.h src/3rdparty/qtsingleapplication/qtsingleapplication.h src/3rdparty/qtsingleapplication/qtlocalpeer.h src/3rdparty/ganalytics/ganalytics.h $(DISTDIR)/
	$(COPY_FILE) --parents src/application/application.cpp src/common/common.cpp src/main.cpp src/systemtray/systemtray.cpp src/application/logfile.cpp src/application/settings.cpp src/network/networkmanager.cpp src/webengine/cookiejar.cpp src/webengine/webengine.cpp src/3rdparty/qtsingleapplication/qtsingleapplication.cpp src/3rdparty/qtsingleapplication/qtlocalpeer.cpp src/3rdparty/ganalytics/ganalytics.cpp $(DISTDIR)/
